@echo off
setlocal
chcp 65001 >nul

echo ==================================================
echo [系统管理] 正在清理存量 Python 进程...
echo ==================================================

:: 强制结束所有 python.exe 进程 (慎用，如果是单机多应用可能会受影响，但对于此专用环境是安全的)
taskkill /f /im python.exe >nul 2>&1

timeout /t 2 /nobreak >nul

echo ==================================================
echo [系统启动] 正在初始化 淘宝价格监控系统 v2025...
echo ==================================================

:: 启动 Flask 后台
start /b python app.py

echo.
echo ==================================================
echo [OK] 服务已启动!
echo 请访问: http://127.0.0.1:5000
echo ==================================================
echo.

:: 保持窗口开启
pause
